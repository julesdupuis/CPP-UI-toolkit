@startuml project

skinparam classAttributeIconSize 0

note as mainNote
    Multiplicities are 1:1 by default
end note

() main
class Game{

}
class Player{
    -position : Vector2
    -speed : float
    +move(Vector2)
    +getPos() : Vector2
    +getSpeed() : float
}
class PlayerListener{

}

main -> Game : calls
Game --> Player
Game --> PlayerListener

package utils{
    class Bag<type>{
        -content : unordered_set<type>
        +add(type)
        +remove(type)
        +foreach(function<void(type)>&)
    }
    class "Bag<Listener*>" as BagListener <<(T,LightBlue)>>

    class Singleton<type>{
        {static} -object : type&
        {static} -initialised : bool
        -Singleton()
        {static} +create(const type&)
        {static} +instance() : const type&
    }
    class "Singleton<EventDispatcher>" as SingletonEventDispatcher <<(T,LightBlue)>>
}

BagListener ..|> Bag
SingletonEventDispatcher ..|> Singleton

package event{
    interface Event
    interface Listener{
        +onEvent(Event&)
    }
    class Observable{
        +subscribe(Listener&)
        +unsubscribe(Listener&)
        +fireEvent(Event&)
    }
    class InputListener{
        {field} -inputTest : function<bool()>
        {field} -action : function<void()>
    }
    class EventDispatcher{
        +dispatch()
        +addInputListener(Listener&)
        +removeInputListener(Listener&)
    }
    class ActiveVariable<type>{
        -variable : type
        +get() : type
        +set(type)
        +addListener(Listener&)
        +removeListener(Listener&)
    }
}

Listener <|.. InputListener : +
Observable <|-- EventDispatcher : -
Observable <|-- ActiveVariable : -
Observable --> BagListener : listeners

InputListener --> EventDispatcher
Game --> EventDispatcher

package component{
    class Component{
        -position : Vector2
        -size : Vector2
        +getPos() : Vector2
        +setPos(Vector2)
        +getSize() : Vector2
        +setSize(Vector2)
    }
    class Drawable{
        -shown : bool
        +draw()
        +show(bool)
    }
    class Button{
        -text : string
    }
}

Component <|-- Drawable : +
Drawable <|-- Button : +
Button --> Observable : actionObservable

package layout{

}

PlayerListener --> "4" InputListener
PlayerListener --> Player
Game --> SingletonEventDispatcher
Game --> Button

@enduml