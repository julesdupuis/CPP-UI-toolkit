@startuml project

skinparam classAttributeIconSize 0

note as mainNote
    Multiplicities are 1:1 by default
    T stereotypes are template instantiations
end note

package app{
    () main
    class Player{
        -position : Vector2
        -speed : float
        +move(Vector2)
        +getPos() : Vector2
        +getSpeed() : float
    }
    class PlayerListener{

    }
}

main --> Player
main --> PlayerListener

package utils{
    class Bag<type>{
        -content : unordered_set<type>
        +add(type)
        +remove(type)
        +foreach(function<void(type)>&)
    }
    class "Bag<Listener*>" as BagListener <<(T,LightBlue)>>

    class Singleton<type>{
        {static} -object : type&
        {static} -initialised : bool
        -Singleton()
        {static} +create(const type&)
        {static} +instance() : const type&
    }
    class "Singleton<EventDispatcher>" as SingletonEventDispatcher <<(T,LightBlue)>>
}

BagListener ..|> Bag
SingletonEventDispatcher ..|> Singleton

package event{
    class Listener{
        -callback : function<void()>
        -enabled : bool
        +isEnabled() : bool
        +enable(bool)
        +onEvent()
    }
    class Observable{
        +subscribe(Listener&)
        +unsubscribe(Listener&)
        +fireEvent()
    }
    class InputListener{
        {field} -inputTest : function<bool()>
        {field} -action : function<void()>
        {field} -actionElse : function<void()>
    }
    class EventDispatcher{
        +dispatch()
        +addInputListener(Listener&)
        +removeInputListener(Listener&)
    }
    class ActiveVariable<type>{
        -variable : type
        +get() : type
        +set(type)
        +addListener(Listener&)
        +removeListener(Listener&)
    }
    class FrameListener{
        {field} -action : function<void()>
    }
}

Listener <|-- FrameListener : +
FrameListener <|-- InputListener : +
Observable <|-- EventDispatcher : -
Observable <|-- ActiveVariable : -

Observable --> BagListener : listeners

FrameListener --> EventDispatcher

package component{
    class Component{
        -position : Vector2
        -size : Vector2
        -shown : bool
        +getPos() : Vector2
        +setPos(Vector2)
        +getSize() : Vector2
        +setSize(Vector2)
        +fit()
        +layout()
        +draw()
        +isShown() : bool
        +show(bool)
        +toStr(ostream)
    }
    class Button{
        -text : string
        -state : State
        -isMouseInside() : bool
        +setText(string)
        +setAction(Action)
    }
    class Action{
        -name : string
    }
    class Container{
        +add(Component&, LayoutContraint constraint)
        +remove(LayoutContraint constraint)
    }
    class Panel{
        -backGroundColor : Color
        +GetBackGroundColor() : Color
        +setBackgroundColor(Color)
    }
    class Window{
        -title : String
        +setTitle(String)
        +run()
    }
    class Label{
        +getTextModel() : TextModel
        +setTextModel(TextModel)
    }
    class FPSLabel{
        -warningValue : int
        -lowValue : int
        -goodColor : Color
        -warningColor : Color
        -lowColor : Color
        +setWarningValue(int)
        +setLowValue(int)
        +setGoodColor(Color)
        +setWarningColor(Color)
        +setLowColor(Color)
    }
    class Box{
        -backgroundColor : Color
        -insets : Vector4
        +getBackgroundColor() : Color
        +setBackGroundColor(Color)
        +getInsets() : Vector4
        +setInsets(Vector4)
        +add(Component)
        +remove()
    }
    class Slider{
        -vertical : bool
        -barThickness : int
        -buttonThickness : int
        +isVertical() : bool
        +setVertical(bool)
        +getBarThickness() : int
        +getButtonThickness() : int
        +setBarThickness(int)
        +setButtonThickness(int)
        +getBoundedRangeModel() : BoundedRangeModel
        +setBoundedRangeModel(BoundedRangeModel)
    }
}

Component <|-- Button : +
Observable <|-- Action : +
Component <|-- Container : +
Container <|-- Panel : +
Panel <|-- Window : +
Component <|-- Label : +
Label <|-- FPSLabel : +
Component <|-- Box : +
Component <|-- Slider : +

Button --> Action
Button --> "2" InputListener

Window --> EventDispatcher
Window ..> SingletonEventDispatcher : initialize

FPSLabel --> FrameListener
Box --> Component
Slider --> "2" Action
Slider --> "2" Listener
Slider --> "2" Button

package layout{
    interface LayoutManager{
        +addComponent(Component, LayoutContraint constraint)
        +removeComponent(LayoutContraint constraint)
        +foreachComponents(function<void(Component)>)
        +layout(Component&)
        +toStr(ostream)
    }
    abstract class OrientedLayout{
        -vertical : bool
        +isVertical() : bool
        +setVertical(bool)
    }
    class BorderLayout{

    }
    class StackLayout{

    }
    class LayeredLayout{

    }
    class FreeLayout{

    }
}

LayoutManager <|-- OrientedLayout : +
OrientedLayout <|.. BorderLayout : +
OrientedLayout <|.. StackLayout : +
LayoutManager <|.. LayeredLayout : +
LayeredLayout <|-- FreeLayout : +

Container --> LayoutManager
BorderLayout --> "3" Component
StackLayout --> "*" Component
LayeredLayout --> "*" Component

package model{
    class TextModel{
        -text : string
        -font : Font
        -fontSize : float
        -spacing : float
        -tint : Color
        +getSize() : Vector2
        +draw()
        +getText() : string
        +setText(string)
        +getFont() : Font
        +setFont(Font)
        +getFontSize() : float
        +setFontSize(float)
        +getSpacing() : float
        +setSpacing(float)
        +getColor() : Color
        +setColor(Color)
    }
    class BoundedRangeModel{
        -minValue : int
        -maxValue : int
        -currentValue : int
        +getMinValue() : int
        +getMaxValue() : int
        +getCurrentValue() : int
        +getRatio() : float
        +setMinValue(int)
        +setMaxValue(int)
        +setCurrentValue(int)
        +setRatio(float)
    }
}

Observable <|-- BoundedRangeModel

Label --> TextModel
Slider --> BoundedRangeModel

PlayerListener --> "4" InputListener
PlayerListener --> Player

main --> Window
main --> Button

@enduml